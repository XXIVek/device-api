<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Админ-панель{% endblock %}</title>
    <style>
        body { font-family: sans-serif; margin: 20px; background: #f5f5f5; }
        .container { max-width: 1200px; margin: 0 auto; }
        nav { background: #333; padding: 10px; border-radius: 5px; margin-bottom: 20px; }
        nav a { color: white; margin-right: 15px; text-decoration: none; }
        nav a:hover { text-decoration: underline; }
        table { border-collapse: collapse; width: 100%; background: white; }
        th, td { border: 1px solid #ddd; padding: 8px; text-align: left; }
        th { background: #f2f2f2; }
        .flash { padding: 10px; margin-bottom: 20px; border-radius: 5px; }
        .flash.error { background: #f8d7da; color: #721c24; }
        .flash.success { background: #d4edda; color: #155724; }
        .pagination { margin-top: 20px; }
    </style>
</head>
<body>
    <div class="container">
        <nav>
            <a href="../admin/dashboard">Главная</a>
            <a href="../admin/organizations">Организации</a>
            <a href="../admin/licenses">Лицензии</a>
            <a href="../admin/devices">Устройства</a>
            <a href="../admin/messages">Сообщения</a>
            <a href="../admin/logout" style="float: right;">Выход</a>
        </nav>
        {% block content %}{% endblock %}
    </div>
</body>
</html>
